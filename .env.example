# Environment Variables for Project Omnilyth

# Proxy URL for production API calls
# Uncomment and set based on your hosting platform:

# For Netlify:
# VITE_PROXY_URL=/.netlify/functions/poe-ninja-proxy

# For Vercel:
# VITE_PROXY_URL=/api/poe-ninja-proxy

# For Cloudflare Workers:
# VITE_PROXY_URL=https://poe-ninja-proxy.YOUR_SUBDOMAIN.workers.dev

# Default: If not set, uses /.netlify/functions/poe-ninja-proxy
